# Copy this file to .env.local and fill in your Supabase project values.
# (Settings -> API in the Supabase dashboard)
# These are REQUIRED — Supabase powers both the live connection (Realtime)
# and cloud photo storage. Add the same two values in Vercel for deployment.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
